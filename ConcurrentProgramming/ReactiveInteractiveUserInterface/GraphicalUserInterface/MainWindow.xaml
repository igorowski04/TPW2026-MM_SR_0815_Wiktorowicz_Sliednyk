<Window x:Class="TP.ConcurrentProgramming.PresentationView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TP.ConcurrentProgramming.Presentation.ViewModel;assembly=TP.ConcurrentProgramming.PresentationViewModel"
        Title="Symulator Kul" Height="550" Width="800">

    <!-- Przypięcie ViewModelu -->
    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Miejsce na pasek sterowania -->
            <RowDefinition Height="50"/>
            <!-- Miejsce na stół -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- PANEL STEROWANIA -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
            <TextBlock Text="Ilość kul:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
            <TextBox Text="{Binding NumberOfBallsInput, UpdateSourceTrigger=PropertyChanged}" 
                     Width="50" Margin="0,0,10,0" VerticalContentAlignment="Center" FontSize="14"/>

            <Button Content="Start" Command="{Binding StartCommand}" Width="80" Background="LightGreen" FontWeight="Bold"/>
        </StackPanel>

        <!-- STÓŁ BILARDOWY -->
        <!-- Usunąłem stąd Width i Height, ramka sama dopasuje się do środka -->
        <Border Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" BorderThickness="4" BorderBrush="Green" Margin="10" Background="WhiteSmoke">
            <ItemsControl ItemsSource="{Binding Balls}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <!-- Twarde wymiary wędrują tutaj! Teraz płótno ma równe 700x400, a ramka je tylko obudowuje -->
                        <Canvas Width="700" Height="400" ClipToBounds="True" Background="Transparent"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Width="{Binding Diameter}" Height="{Binding Diameter}" Fill="Coral" Stroke="Black"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>

            </ItemsControl>
        </Border>
    </Grid>
</Window>